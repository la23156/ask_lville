{
  "name": "ask-lville",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "install:all": "npm --prefix server install && npm --prefix web install",
    "ingest": "npm --prefix server run ingest",
    "server": "npm --prefix server run dev",
    "web": "npm --prefix web run dev",
    "dev": "concurrently -n server,web -c red.cyan \"npm:server\" \"npm:web\"",
    "build": "npm --prefix web run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
